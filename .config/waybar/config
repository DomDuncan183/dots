{
    "layer": "top",
    "width": 1800,
    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["hyprland/window"],
    "modules-right": ["custom/reset", "custom/wall", "wireplumber", "clock"],

    "hyprland/workspaces": {
        //"on-scroll-up": "hyprctl dispatch workspace +1",
        //"on-scroll-down": "hyprctl dispatch workspace -1",
        "format": "{icon}",
        "format-icons": {
        	"active": "",
            "default": "",
        },
        "persistent_workspaces": {
            "DP-1": 10
        }
    },

    "wireplumber": {
        "format": "{volume}% {icon}",
        "format-icons": ["", "", ""],
        "format-muted": "󰝟",
        "scroll-step": 5,
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
    },

    "clock": {
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },

    "custom/wall":{
        "format":"󰸉",
        "exec": "~/.config/waybar/scripts/expand wall",
        // "interval": 1,
        "on-click": "~/.config/waybar/scripts/expand cycle"
    },

    "custom/reset": {
        "format": "󰑌",
        "on-click": "killall waybar && waybar &"
    }
}

